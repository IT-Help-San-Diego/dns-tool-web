modules = ["python-3.11", "nodejs-20", "go-1.23", "web", "bash", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["amass", "cacert", "chromium", "dnsutils", "dnsx", "fontconfig", "freetype", "ghostscript", "glib", "harfbuzz", "httpx", "imagemagick", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "nmap", "nmap-formatter", "nuclei", "openjpeg", "openssl", "pango", "postgresql", "potrace", "python312Packages.nmapthon2", "rsync", "sqlc", "subfinder", "tcl", "testssl", "tk", "unzip", "whois", "zlib"]

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "./dns-tool-server"]
build = ["bash", "build.sh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./dns-tool-server"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
SONAR_ORG = "careyjames"
SONAR_PROJECT = "careyjames_DnsToolWeb"
SMTP_PROBE_MODE = "remote"
MAINTENANCE_NOTE = "Developing!"
ANALYTICS_EXCLUDE_IPS = "76.218.253.212"

[userenv.development]
BASE_URL = "https://f2c73519-b3f3-4c33-90b1-699f833acae8-00-2qa7mtebx8ii8.picard.replit.dev"

[agent]
integrations = ["github:1.0.0", "notion:1.0.0"]
